# Optional: use one provider for AI cover-letter generation.
# The app still works without these keys by using a local template.

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Optional: change the local port the Flask app runs on (default 5000)
PORT=5000
